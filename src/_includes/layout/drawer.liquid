<div id="drawer">
  {% comment %} <img class="drawer-image" src="https://cdn.donmai.us/original/ba/41/__me_tan_os_tan_drawn_by_blubot__ba414bd3e42f7086451ac740b56b0956.png"> {% endcomment %}
  <div class="drawer-header">
    <div class="drawer-title">Windows Manager</div>
    <div class="drawer-control close">
        <svg style="height: 24px" fill="#ffffff" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M5 5h2v2H5V5zm4 4H7V7h2v2zm2 2H9V9h2v2zm2 0h-2v2H9v2H7v2H5v2h2v-2h2v-2h2v-2h2v2h2v2h2v2h2v-2h-2v-2h-2v-2h-2v-2zm2-2v2h-2V9h2zm2-2v2h-2V7h2zm0 0V5h2v2h-2z" fill="currentColor"/>
        </svg>
    </div>
  </div>
  <div class="drawer-content">
    <div class="drawer-section">
      <div class="drawer-section-title">Pages</div>
      <div class="drawer-section-content">
        <ul class="drawer-section-checkboxes">
          {% for w in windows.pages %}
            <li>
              <input class="drawer-checkbox" type="checkbox" name="{{ w.windowTitle }}" {% if w.visible %}checked{% endif %}>
              <label for="{{ w.windowTitle }}">{{w.windowTitle}}</label>
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>
    
    <div class="drawer-section">
      <div class="drawer-section-title">Widgets</div>
      <div class="drawer-section-content">
        <ul class="drawer-section-checkboxes">
          <p>No Widgets found</p>
        </ul>
      </div>
    </div>

    <div class="drawer-section">
      <div class="drawer-section-title">Misc</div>
      <div class="drawer-section-content">
        <ul class="drawer-section-checkboxes">
          <p>No Misc Items found</p>
        </ul>
      </div>
    </div>
  </div>
</div>